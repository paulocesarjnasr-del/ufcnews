generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model amizades {
  id                                                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id                                         String          @db.Uuid
  amigo_id                                           String          @db.Uuid
  status                                             status_amizade? @default(pendente)
  created_at                                         DateTime?       @default(now()) @db.Timestamptz(6)
  accepted_at                                        DateTime?       @db.Timestamptz(6)
  usuarios_arena_amizades_amigo_idTousuarios_arena   usuarios_arena  @relation("amizades_amigo_idTousuarios_arena", fields: [amigo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios_arena_amizades_usuario_idTousuarios_arena usuarios_arena  @relation("amizades_usuario_idTousuarios_arena", fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuario_id, amigo_id], map: "amizade_unica")
  @@index([amigo_id], map: "idx_amizades_amigo")
  @@index([usuario_id], map: "idx_amizades_usuario")
}

model analises {
  id                                        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  evento_id                                 String?    @db.Uuid
  slug                                      String     @unique @db.VarChar(255)
  titulo                                    String     @db.VarChar(500)
  subtitulo                                 String?
  lutador1_id                               String?    @db.Uuid
  lutador2_id                               String?    @db.Uuid
  artigo_conteudo                           String
  tactical_breakdown                        Json       @default("{}")
  fight_prediction                          Json       @default("{}")
  fighter1_info                             Json       @default("{}")
  fighter2_info                             Json       @default("{}")
  evento_nome                               String?    @db.VarChar(255)
  evento_data                               DateTime?  @db.Timestamptz(6)
  evento_local                              String?    @db.VarChar(255)
  categoria_peso                            String?    @db.VarChar(100)
  num_rounds                                Int?       @default(5)
  is_titulo                                 Boolean?   @default(false)
  broadcast                                 String?    @db.VarChar(255)
  status                                    String?    @default("publicado") @db.VarChar(20)
  fights_analysis                           Json?
  card_overview                             Json?
  analysis_type                             String?    @default("single_fight") @db.VarChar(20)
  created_at                                DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                                DateTime?  @default(now()) @db.Timestamptz(6)
  eventos                                   eventos?   @relation(fields: [evento_id], references: [id], onUpdate: NoAction)
  lutadores_analises_lutador1_idTolutadores lutadores? @relation("analises_lutador1_idTolutadores", fields: [lutador1_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lutadores_analises_lutador2_idTolutadores lutadores? @relation("analises_lutador2_idTolutadores", fields: [lutador2_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_analises_created")
  @@index([evento_id], map: "idx_analises_evento")
  @@index([slug], map: "idx_analises_slug")
  @@index([status], map: "idx_analises_status")
}

model atividades {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id     String         @db.Uuid
  tipo           String         @db.VarChar(50)
  titulo         String         @db.VarChar(100)
  descricao      String?
  dados          Json?
  publica        Boolean?       @default(true)
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  usuarios_arena usuarios_arena @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_atividades_created")
  @@index([usuario_id], map: "idx_atividades_usuario")
}

model comentarios {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  noticia_id        String        @db.Uuid
  parent_id         String?       @db.Uuid
  autor_nome        String        @db.VarChar(50)
  autor_email       String?       @db.VarChar(255)
  autor_fingerprint String        @db.VarChar(64)
  conteudo          String
  status            String?       @default("aprovado") @db.VarChar(20)
  reportado_count   Int?          @default(0)
  created_at        DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?     @default(now()) @db.Timestamptz(6)
  noticias          noticias      @relation(fields: [noticia_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  comentarios       comentarios?  @relation("comentariosTocomentarios", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_comentarios comentarios[] @relation("comentariosTocomentarios")

  @@index([created_at(sort: Desc)], map: "idx_comentarios_created")
  @@index([autor_fingerprint], map: "idx_comentarios_fingerprint")
  @@index([noticia_id], map: "idx_comentarios_noticia")
  @@index([parent_id], map: "idx_comentarios_parent")
  @@index([status], map: "idx_comentarios_status")
}

model comentarios_rate_limit {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fingerprint String    @db.VarChar(64)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_rate_limit_created")
  @@index([fingerprint], map: "idx_rate_limit_fingerprint")
}

model conquistas {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id      String         @db.Uuid
  tipo            tipo_conquista
  detalhes        Json?
  desbloqueada_em DateTime?      @default(now()) @db.Timestamptz(6)
  usuarios_arena  usuarios_arena @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuario_id, tipo], map: "conquista_unica")
  @@index([tipo], map: "idx_conquistas_tipo")
  @@index([usuario_id], map: "idx_conquistas_usuario")
}

