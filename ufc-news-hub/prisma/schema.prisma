model evento_pontuacao {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  evento_id           String         @db.Uuid
  usuario_id          String         @db.Uuid
  pontos_totais       Int?           @default(0)
  acertos             Int?           @default(0)
  total_lutas         Int?           @default(0)
  previsoes_perfeitas Int?           @default(0)
  card_perfeito       Boolean?       @default(false)
  created_at          DateTime?      @default(now()) @db.Timestamptz(6)
  eventos             eventos        @relation(fields: [evento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios_arena      usuarios_arena @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([evento_id, usuario_id], map: "evento_usuario_unico")
  @@index([evento_id, pontos_totais(sort: Desc)], map: "idx_evento_pontuacao_evento")
  @@index([usuario_id], map: "idx_evento_pontuacao_usuario")
}

