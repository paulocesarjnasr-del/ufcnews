// ═══════════════════════════════════════
// AI COMPANY MODELS
// ═══════════════════════════════════════

model Agent {
  id           String   @id // "ceo", "cso", "news-writer", etc.
  humanName    String
  codename     String
  role         String
  title        String
  model        String   // "opus-4.6", "sonnet-4.5", "haiku-4.5"
  modelReason  String   @default("")
  systemPrompt String   @db.Text
  desc         String   @default("")
  status       String   @default("active") // active, idle, warning, error, offline
  level        String   // executive, director, agent
  icon         String
  color        String

  // Hierarchy
  reportsTo String?
  reports   String[] // IDs of direct reports

  // Avatar
  avatarUrl String?

  // Stats
  tasksCompleted Int       @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // XP & LEVELING SYSTEM
  agentLevel    Int      @default(1) // L1=Trainee, L2=Specialist, L3=Senior, L4=Lead
  levelTitle    String   @default("Trainee")
  xp            Int      @default(0)
  xpToNextLevel Int      @default(100)

  // PERFORMANCE TRACKING
  weeklyScore                 Float @default(0)   // 0-5, calculado semanalmente
  weeklyTaskCount             Int   @default(0)
  weeklySuccessRate           Float @default(0)   // 0-1
  avgResponseTime             Float @default(0)   // tempo medio em ms
  consecutiveWeeksAboveTarget Int   @default(0)
  consecutiveWeeksBelowTarget Int   @default(0)
  warnings                    Int   @default(0)

  // HISTORY
  promotedAt DateTime?
  demotedAt  DateTime?
  hiredAt    DateTime  @default(now())
  firedAt    DateTime? // null = empregado ativo

  // Relations
  tasks              AgentTask[]
  logs               AgentLog[]
  approvals          Approval[]          @relation("agent_approvals")
  performanceReviews PerformanceReview[]
  costLogs           AgentCostLog[]      @relation("agent_costs")

  @@map("agents")
}

model AgentTask {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  type   String  @default("prompt_response")
  input  String  @db.Text
  output String? @db.Text
  status String  @default("pending") // pending, running, completed, failed, awaiting_approval

  parentTaskId String?
  parentTask   AgentTask?  @relation("subtasks", fields: [parentTaskId], references: [id])
  subtasks     AgentTask[] @relation("subtasks")

  modelUsed    String?
  tokensInput  Int?
  tokensOutput Int?
  durationMs   Int?
  error        String? @db.Text

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  approvals Approval[]

  @@index([agentId])
  @@index([status])
  @@map("agent_tasks")
}

model Approval {
  id      String    @id @default(cuid())
  taskId  String
  task    AgentTask @relation(fields: [taskId], references: [id])
  agentId String
  agent   Agent     @relation("agent_approvals", fields: [agentId], references: [id])

  actionType  String
  description String  @db.Text
  payload     String  @db.Text

  status     String    @default("pending") // pending, approved, rejected
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([status])
  @@map("approvals")
}

model AgentLog {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  level    String
  message  String  @db.Text
  metadata String? @db.Text

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([level])
  @@map("agent_logs")
}

model CompanyPrompt {
  id     String @id @default(cuid())
  userId String
  prompt String @db.Text

  ceoAnalysis String? @db.Text
  status      String  @default("processing")

  tasks   String[]
  summary String?  @db.Text

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("company_prompts")
}

model AgentCostLog {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation("agent_costs", fields: [agentId], references: [id])
  tokensInput  Int
  tokensOutput Int
  costUsd      Float
  model        String
  taskId       String?
  createdAt    DateTime @default(now())

  @@index([agentId])
  @@index([createdAt])
  @@map("agent_cost_logs")
}

model AgentEvent {
  id          String    @id @default(cuid())
  type        String    // event.finalized, event.new_card, news.synced, cron.daily, cron.weekly
  payload     String    @db.Text
  status      String    @default("pending") // pending, processing, completed, failed
  error       String?   @db.Text
  triggeredAt DateTime  @default(now())
  processedAt DateTime?

  @@index([status])
  @@index([type])
  @@index([triggeredAt(sort: Desc)])
  @@map("agent_events")
}

model RemediationPlan {
  id         String    @id @default(cuid())
  promptId   String?   // CompanyPrompt that originated this plan
  analysis   String    @db.Text // CEO analysis of what needs to improve
  actions    String    @db.Text // JSON: [{ agentId, instruction, priority, autoApprove }]
  status     String    @default("pending") // pending, approved, executing, completed, rejected
  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  approvedBy String?
  executedAt DateTime?
  results    String?   @db.Text // JSON with execution results

  @@index([status])
  @@map("remediation_plans")
}

model PerformanceReview {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  weekNumber Int
  year       Int

  // Metrics
  tasksCompleted    Int
  tasksFailed       Int
  avgResponseTimeMs Int
  tokensUsed        Int
  costUsd           Float
  successRate       Float // 0-1
  qualityScore      Float // 0-5
  efficiencyScore   Float // 0-5

  // Composite
  weeklyScore Float // 0-5, media ponderada
  xpEarned    Int

  // Actions
  action String? // "promoted" | "demoted" | "warning" | "employee_of_week" | null

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([year, weekNumber])
  @@map("performance_reviews")
}
